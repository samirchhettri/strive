rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Global Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return request.auth.uid == userId; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // --- Entity Validation ---
    function isValidUser(data) {
      return data.uid is string && 
             data.displayName is string && 
             data.totalPoints is int && 
             data.streak is int &&
             data.totalPoints >= 0 &&
             data.streak >= 0;
    }

    // --- Collections ---

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isOwner(userId) && 
        isValidUser(incoming()) &&
        incoming().totalPoints == 0 &&
        incoming().streak == 0;
        
      allow update: if isSignedIn() && isOwner(userId) &&
        isValidUser(incoming()) &&
        incoming().uid == userId &&
        (
          // Allow point increment & streak update
          incoming().diff(existing()).affectedKeys().hasOnly(['totalPoints', 'streak', 'lastActiveDate']) &&
          incoming().totalPoints >= existing().totalPoints
        );
    }

    match /challenges/{date} {
      allow read: if isSignedIn();
      // Allow the 'ping' check used in connection test
      allow read: if true; 
      // Only allow creation/caching if it doesn't exist
      allow create: if isSignedIn();
    }

    match /completions/{completionId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && 
        incoming().userId == request.auth.uid &&
        isValidId(incoming().challengeId) &&
        existsAfter(/databases/$(database)/documents/users/$(request.auth.uid));
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
  }
}

