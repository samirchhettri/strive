{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user stats and profile info.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "totalPoints": { "type": "integer" },
        "streak": { "type": "integer" },
        "lastActiveDate": { "type": "string", "format": "date" },
        "lastChallengeReset": { "type": "string", "format": "date" }
      },
      "required": ["uid", "totalPoints", "streak"]
    },
    "DailyChallenge": {
      "title": "Daily Challenge",
      "description": "A set of challenges generated by AI for a specific date.",
      "type": "object",
      "properties": {
        "date": { "type": "string", "format": "date" },
        "challenges": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "text": { "type": "string" },
              "category": { "type": "string", "enum": ["Fitness", "Productivity", "Social", "Mindset"] },
              "points": { "type": "integer" }
            }
          }
        }
      }
    },
    "Completion": {
      "title": "Challenge Completion",
      "description": "Records when a user completes a specific challenge.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "challengeId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Main user documents."
    },
    "/challenges/{date}": {
      "schema": "DailyChallenge",
      "description": "Global daily challenges cached by date."
    },
    "/completions/{completionId}": {
      "schema": "Completion",
      "description": "Records of challenge completion."
    }
  }
}
